{
  "name": "@v-vanguard/qr-reader-vue2",
  "version": "0.3.0",
  "description": "iPad向け極小QRコードスキャナー Web Component (Wasm 製デコーダ)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/v-vanguard/demo-qr-reader.git"
  },
  "type": "module",
  "main": "./dist/qr-reader.umd.cjs",
  "module": "./dist/qr-reader.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/qr-reader.mjs",
      "require": "./dist/qr-reader.umd.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "wasm:build": "wasm-pack build wasm --target web --release --out-dir ../pkg --out-name qr_reader_wasm",
    "wasm:check": "cargo check --manifest-path wasm/Cargo.toml",
    "wasm:test": "cargo test --manifest-path wasm/Cargo.toml",
    "build": "vite build",
    "build:all": "npm run wasm:build && npm run build",
    "dev": "vite",
    "version": "npm run build:all && git add dist",
    "release:public": "bash scripts/release-public.sh"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0",
    "wasm-pack": "^0.13.1"
  }
}
